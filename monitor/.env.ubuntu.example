PUBLIC_LISTENER_TARGETS_JSON='[{"id":"geral","name":"Geral / Tudo","url":"https://scrc.radiocabrito.com:13386/;"},{"id":"modao","name":"Modao","url":"https://scrc.radiocabrito.com:14054/;"},{"id":"festa","name":"Festa / Universitario","url":"https://scrc.radiocabrito.com:13542/;"}]'
PUBLIC_LISTENER_DEBUG=true
PUBLIC_LISTENER_SAMPLE_DURATION_SECONDS=20
PUBLIC_LISTENER_SILENCE_THRESHOLD_DB=-45
PUBLIC_LISTENER_CONTINUOUS_SILENCE_SECONDS=12
PUBLIC_LISTENER_TOTAL_TIMEOUT_MS=30000
PUBLIC_LISTENER_REQUIRE_TLS=true
PUBLIC_LISTENER_FFMPEG_PATH=ffmpeg
PUBLIC_LISTENER_FFPROBE_PATH=ffprobe
# Opcional: sobrescreve o snapshot local de incidentes.
# Caminhos relativos sao resolvidos a partir do diretorio corrente de execucao da CLI.
# PUBLIC_LISTENER_INCIDENT_STATE_PATH=tmp/incidents-state.sim.json
# Opcional: sobrescreve o snapshot local do outbox de eventos notificaveis.
# Caminhos relativos seguem a mesma regra do state path.
# Se nao for definido, a producao continua usando data/notifiable-events-outbox.json.
# PUBLIC_LISTENER_INCIDENT_OUTBOX_PATH=tmp/notifiable-events-outbox.sim.json
# Opcional: adapter usado pelo dispatcher local do outbox.
# Valores aceitos: log, noop.
# PUBLIC_LISTENER_DISPATCH_ADAPTER=log
# Opcional: modo do adapter noop para simular sucesso ou falha.
# Valores aceitos: success, retryable_error, permanent_error.
# PUBLIC_LISTENER_DISPATCH_NOOP_MODE=success
# Opcional: TTL do lock do dispatcher em milissegundos. Padrao: 600000.
# PUBLIC_LISTENER_DISPATCH_LOCK_TTL_MS=600000
# Opcional: backoff base do retry em milissegundos. Padrao: 300000.
# PUBLIC_LISTENER_DISPATCH_RETRY_BASE_MS=300000
# Opcional: backoff maximo do retry em milissegundos. Padrao: 21600000.
# PUBLIC_LISTENER_DISPATCH_RETRY_MAX_MS=21600000
# Opcional: quantidade maxima de tentativas antes de descartar. Padrao: 10.
# PUBLIC_LISTENER_DISPATCH_MAX_ATTEMPTS=10

PUBLIC_LISTENER_URL=https://scrc.radiocabrito.com:13386/;
PUBLIC_LISTENER_TARGETS_JSON=[{"id":"geral","name":"Geral / Tudo","url":"https://scrc.radiocabrito.com:13386/;"},{"id":"modao","name":"Modao","url":"https://scrc.radiocabrito.com:14054/;"},{"id":"festa","name":"Festa / Universitario","url":"https://scrc.radiocabrito.com:13542/;"}]
PUBLIC_LISTENER_USER_AGENT=RadioCabritoPublicListenerCheck/1.0
PUBLIC_LISTENER_TOTAL_TIMEOUT_MS=30000
PUBLIC_LISTENER_SAMPLE_DURATION_SECONDS=10
PUBLIC_LISTENER_SILENCE_THRESHOLD_DB=-45
PUBLIC_LISTENER_CONTINUOUS_SILENCE_SECONDS=5
PUBLIC_LISTENER_REQUIRE_TLS=true
PUBLIC_LISTENER_FFMPEG_PATH=ffmpeg
PUBLIC_LISTENER_FFPROBE_PATH=ffprobe
PUBLIC_LISTENER_DEBUG=false
# Opcional: adapter do dispatcher do outbox. Mantem log como padrao.
# Para notificacao real, o canal operacional escolhido e telegram.
# PUBLIC_LISTENER_DISPATCH_ADAPTER=telegram
# Opcional: token do bot Telegram para o adapter telegram.
# PUBLIC_LISTENER_TELEGRAM_BOT_TOKEN=
# Opcional: chat ID do Telegram para o adapter telegram.
# PUBLIC_LISTENER_TELEGRAM_CHAT_ID=
# Opcional: prefixo curto da mensagem do Telegram.
# PUBLIC_LISTENER_TELEGRAM_MESSAGE_PREFIX=[monitor-local]
# Opcional: arquivo local usado pelo telegram-status-bot para persistir o offset do getUpdates.
# PUBLIC_LISTENER_TELEGRAM_STATUS_OFFSET_PATH=data/telegram-status-offset.json
# Opcional: timeout do long polling do telegram-status-bot, em segundos.
# PUBLIC_LISTENER_TELEGRAM_STATUS_POLL_TIMEOUT_SECONDS=25
# Opcional: quando true, o telegram-status-bot processa uma rodada e sai.
# PUBLIC_LISTENER_TELEGRAM_STATUS_ONCE=false
